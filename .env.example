APP_NAME="VYOMIKA ATELIER"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://vyomikaatelier.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vyomika_atelier
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database

# Use sync on shared hosting (Hostinger) unless you run a queue worker cron.
# database/redis queues mark emails as sent before jobs run — without queue:work, mail is lost.
QUEUE_CONNECTION=sync

# Cloudflare Email Sending (https://developers.cloudflare.com/email-service/api/send-emails/smtp/)
# Domain must be onboarded under Cloudflare → Email → Email Sending.
# Username is literally "api_token"; password is a Cloudflare API token with Email Sending: Edit.
MAIL_MAILER=smtp
MAIL_HOST=smtp.mx.cloudflare.net
MAIL_PORT=465
MAIL_USERNAME=api_token
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="namaste@vyomikaatelier.com"
MAIL_FROM_NAME="${APP_NAME}"

# Optional — only needed for Cloudflare REST API integrations (not required for SMTP above)
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=

# Razorpay Standard Checkout (test or live keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Legacy names still supported:
# RAZORPAY_KEY=
# RAZORPAY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

ADMIN_EMAIL=admin@vyomikaatelier.com

# Cancel unpaid orders after this many hours (stock reservation release)
ORDER_PENDING_EXPIRY_HOURS=24

# Set before first db:seed on production. Local dev may use changeme123 if unset.
ADMIN_PASSWORD=

# WhatsApp Business Cloud API (required for customer account OTP)
WHATSAPP_DRIVER=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=vyomika_otp
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
