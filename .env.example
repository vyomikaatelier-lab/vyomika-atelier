APP_NAME="VYOMIKA ATELIER"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_URL=https://vyomikaatelier.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vyomika_atelier
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="namaste@vyomikaatelier.com"
MAIL_FROM_NAME="${APP_NAME}"

# Razorpay (add keys when ready)
RAZORPAY_KEY=
RAZORPAY_SECRET=

ADMIN_EMAIL=admin@vyomikaatelier.com

# Set before first db:seed on production. Local dev may use changeme123 if unset.
ADMIN_PASSWORD=

# WhatsApp Business Cloud API (required for customer account OTP)
WHATSAPP_DRIVER=meta
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE_NAME=vyomika_otp
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_API_VERSION=v21.0
